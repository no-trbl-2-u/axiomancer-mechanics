{
  "name": "axiomancer-mechanics",
  "version": "1.0.0",
  "description": "Turn-based RPG game engine with Heart/Body/Mind combat. Embeddable in any UI (React Native, web, Node).",
  "license": "ISC",
  "author": "",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.mjs",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/esm/index.d.ts", "default": "./dist/esm/index.mjs" },
      "require": { "types": "./dist/cjs/index.d.cts", "default": "./dist/cjs/index.cjs" }
    },
    "./character": {
      "import": { "types": "./dist/esm/character/index.d.ts", "default": "./dist/esm/character/index.mjs" },
      "require": { "types": "./dist/cjs/character/index.d.cts", "default": "./dist/cjs/character/index.cjs" }
    },
    "./enemy": {
      "import": { "types": "./dist/esm/enemy/index.d.ts", "default": "./dist/esm/enemy/index.mjs" },
      "require": { "types": "./dist/cjs/enemy/index.d.cts", "default": "./dist/cjs/enemy/index.cjs" }
    },
    "./combat": {
      "import": { "types": "./dist/esm/combat/index.d.ts", "default": "./dist/esm/combat/index.mjs" },
      "require": { "types": "./dist/cjs/combat/index.d.cts", "default": "./dist/cjs/combat/index.cjs" }
    },
    "./effects": {
      "import": { "types": "./dist/esm/effects/index.d.ts", "default": "./dist/esm/effects/index.mjs" },
      "require": { "types": "./dist/cjs/effects/index.d.cts", "default": "./dist/cjs/effects/index.cjs" }
    },
    "./items": {
      "import": { "types": "./dist/esm/items/index.d.ts", "default": "./dist/esm/items/index.mjs" },
      "require": { "types": "./dist/cjs/items/index.d.cts", "default": "./dist/cjs/items/index.cjs" }
    },
    "./skills": {
      "import": { "types": "./dist/esm/skills/index.d.ts", "default": "./dist/esm/skills/index.mjs" },
      "require": { "types": "./dist/cjs/skills/index.d.cts", "default": "./dist/cjs/skills/index.cjs" }
    },
    "./npcs": {
      "import": { "types": "./dist/esm/npcs/index.d.ts", "default": "./dist/esm/npcs/index.mjs" },
      "require": { "types": "./dist/cjs/npcs/index.d.cts", "default": "./dist/cjs/npcs/index.cjs" }
    },
    "./world": {
      "import": { "types": "./dist/esm/world/index.d.ts", "default": "./dist/esm/world/index.mjs" },
      "require": { "types": "./dist/cjs/world/index.d.cts", "default": "./dist/cjs/world/index.cjs" }
    },
    "./game": {
      "import": { "types": "./dist/esm/game/index.d.ts", "default": "./dist/esm/game/index.mjs" },
      "require": { "types": "./dist/cjs/game/index.d.cts", "default": "./dist/cjs/game/index.cjs" }
    },
    "./store": {
      "import": { "types": "./dist/esm/store/index.d.ts", "default": "./dist/esm/store/index.mjs" },
      "require": { "types": "./dist/cjs/store/index.d.cts", "default": "./dist/cjs/store/index.cjs" }
    },
    "./utils": {
      "import": { "types": "./dist/esm/utils/index.d.ts", "default": "./dist/esm/utils/index.mjs" },
      "require": { "types": "./dist/cjs/utils/index.d.cts", "default": "./dist/cjs/utils/index.cjs" }
    },
    "./persistence": {
      "import": { "types": "./dist/esm/persistence/index.d.ts", "default": "./dist/esm/persistence/index.mjs" },
      "require": { "types": "./dist/cjs/persistence/index.d.cts", "default": "./dist/cjs/persistence/index.cjs" }
    },
    "./persistence/node": {
      "import": { "types": "./dist/esm/persistence/node.d.ts", "default": "./dist/esm/persistence/node.mjs" },
      "require": { "types": "./dist/cjs/persistence/node.d.cts", "default": "./dist/cjs/persistence/node.cjs" }
    },
    "./persistence/async-storage": {
      "import": { "types": "./dist/esm/persistence/async-storage.d.ts", "default": "./dist/esm/persistence/async-storage.mjs" },
      "require": { "types": "./dist/cjs/persistence/async-storage.d.cts", "default": "./dist/cjs/persistence/async-storage.cjs" }
    },
    "./persistence/web-storage": {
      "import": { "types": "./dist/esm/persistence/web-storage.d.ts", "default": "./dist/esm/persistence/web-storage.mjs" },
      "require": { "types": "./dist/cjs/persistence/web-storage.d.cts", "default": "./dist/cjs/persistence/web-storage.cjs" }
    },
    "./content": {
      "import": { "types": "./dist/esm/content/index.d.ts", "default": "./dist/esm/content/index.mjs" },
      "require": { "types": "./dist/cjs/content/index.d.cts", "default": "./dist/cjs/content/index.cjs" }
    },
    "./content/effects": {
      "import": { "types": "./dist/esm/content/effects/index.d.ts", "default": "./dist/esm/content/effects/index.mjs" },
      "require": { "types": "./dist/cjs/content/effects/index.d.cts", "default": "./dist/cjs/content/effects/index.cjs" }
    },
    "./content/enemies": {
      "import": { "types": "./dist/esm/content/enemies/index.d.ts", "default": "./dist/esm/content/enemies/index.mjs" },
      "require": { "types": "./dist/cjs/content/enemies/index.d.cts", "default": "./dist/cjs/content/enemies/index.cjs" }
    },
    "./content/items": {
      "import": { "types": "./dist/esm/content/items/index.d.ts", "default": "./dist/esm/content/items/index.mjs" },
      "require": { "types": "./dist/cjs/content/items/index.d.cts", "default": "./dist/cjs/content/items/index.cjs" }
    },
    "./content/world": {
      "import": { "types": "./dist/esm/content/world/index.d.ts", "default": "./dist/esm/content/world/index.mjs" },
      "require": { "types": "./dist/cjs/content/world/index.d.cts", "default": "./dist/cjs/content/world/index.cjs" }
    },
    "./fixtures": {
      "import": { "types": "./dist/esm/fixtures/index.d.ts", "default": "./dist/esm/fixtures/index.mjs" },
      "require": { "types": "./dist/cjs/fixtures/index.d.cts", "default": "./dist/cjs/fixtures/index.cjs" }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "type-check": "tsc --noEmit",
    "check": "npm run lint && npm run type-check"
  },
  "keywords": [
    "rpg",
    "combat",
    "mechanics",
    "turn-based",
    "ttrpg",
    "game-engine"
  ],
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "@react-native-async-storage/async-storage": "*",
    "zustand": "^5"
  },
  "peerDependenciesMeta": {
    "@react-native-async-storage/async-storage": { "optional": true },
    "zustand": { "optional": true }
  },
  "devDependencies": {
    "tsup": "^8",
    "vitest": "^4.1.4",
    "zustand": "^5.0.11"
  }
}
