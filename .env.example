# Environment variables for the autonomous loop.
# Copy to .env and fill in values. Never commit .env.

# --- GitHub (for /triage and issue mirroring) ---

# Personal access token with repo + issues scope.
# Get one: https://github.com/settings/tokens
GH_TOKEN=github_pat_...

# Repo slug (default is already set in skills/march.md and skills/triage.md)
GH_REPO=no-trbl-2-u/axiomancer-mechanics

# --- No deploy token needed ---
# npm run deploy:check uses `npm pack --dry-run` which requires no auth.

# --- Optional: combat CLI ---
# Set to 1 to skip animation delays in the interactive combat CLI.
# COMBAT_NO_DELAY=1
